        ttk.Radiobutton(mode_frame, text="图片模式（精确重复 + 相似图片）", variable=self.mode, value="image", command=self.on_mode_change).grid(row=0, column=1, padx=5, pady=2)
        
        # 相似度滑块（仅图片模式显示）
