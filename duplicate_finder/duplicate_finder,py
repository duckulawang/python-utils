        Label(ctrl_frame, textvariable=self.status_text).pack(side="left", padx=10)
        
        # 结果区域
        result_frame = Labelframe(self.root, text="扫描结果", padx=5, pady=5)
        result_frame.pack(fill="both", expand=True, padx=10, pady=5)
        
        # 结果树
        tree_frame = Frame(result_frame)
