# 支持的文件扩展名（文件模式扫描所有文件，图片模式仅扫描以下扩展名）
IMAGE_EXTENSIONS = {'.jpg', '.jpeg', '.png', '.bmp', '.gif', '.tiff', '.webp', '.ico'}

class DuplicateFinder:
    def __init__(self, root):
        self.root = root
        root.title("重复文件查找工具")
        root.geometry("900x700")
        root.minsize(800, 600)
        
        # 状态变量
        self.scanning = False
        self.stop_requested = False
        self.root_dir = StringVar()
        self.mode = StringVar(value="file")  # file 或 image
        self.similarity_threshold = IntVar(value=5)  # 汉明距离阈值
        self.exclude_dirs = []  # 排除文件夹列表
        self.progress_value = IntVar(value=0)
        self.status_text = StringVar(value="就绪")
        self.result_data = []  # 存储结果组，每组为 (group_type, files_list) group_type: 'exact' or 'similar'
        self.selected_files = set()  # 用户选中的文件路径
        
        # 工作队列
        self.gui_queue = queue.Queue()
        
        self.setup_ui()
        self.check_queue()
        
